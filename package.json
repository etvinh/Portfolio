{
  "name": "brick-voyage",
  "version": "0.1.0",
  "private": true,
  "description": "3D voxel portfolio — sail a brick boat between islands. Next.js + React + Three.js + Postgres.",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "predev": "npm run lint",
    "dev": "next dev",
    "prebuild": "npm run lint",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "pretest": "npm run lint",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest --no-file-parallelism",
    "test:ui": "vitest run --no-file-parallelism test/ui",
    "test:services": "vitest run --no-file-parallelism test/services",
    "test:coverage": "vitest run --no-file-parallelism --coverage",
    "setup": "cp -n .env.example .env || true && npm install && npm run db:up",
    "package": "docker buildx build --platform linux/amd64 -t brickvoyage:latest --load . && mkdir -p dist && docker save brickvoyage:latest | gzip > dist/brickvoyage.tar.gz && echo \"\\n→ dist/brickvoyage.tar.gz ready ($(du -h dist/brickvoyage.tar.gz | cut -f1))\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.0",
    "next": "^15.0.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "three": "^0.160.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.10.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
