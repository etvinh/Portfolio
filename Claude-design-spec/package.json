{
  "name": "brick-voyage",
  "version": "0.1.0",
  "private": true,
  "description": "3D voxel portfolio — sail a brick boat between islands. Next.js + React + Three.js + Postgres.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",

    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx lib/db/seed.ts",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest run test/ui",
    "test:services": "vitest run test/services",
    "test:coverage": "vitest run --coverage",

    "setup": "cp -n .env.example .env || true && npm install && npm run db:up && sleep 4 && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.160.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/user-event": "^14.5.0",
    "jsdom": "^25.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0"
  }
}
