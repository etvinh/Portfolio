# Copy to .env and fill in. Never commit the real .env.

# Dev database (docker compose service "db")
DATABASE_URL=postgresql://brick:brick@localhost:5432/brickvoyage

# Test database (used by Vitest service tests — must be a SEPARATE db)
DATABASE_URL_TEST=postgresql://brick:brick@localhost:5432/brickvoyage_test

# Long random string for signing session cookies / JWTs.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
