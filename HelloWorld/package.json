  "license": "UNLICENSED",
  "repository": "none",
  "dependencies": {
    "@emotion/react": "*",
    "@emotion/styled": "*",
    "@mui/icons-material": "*",
    "@mui/material": "*",
    "dotenv": "*",
    "jose": "*",
    "next": "*",
    "pg": "*",
    "react": "*",
    "react-dom": "*",
    "server-only": "*"
  },
  "devDependencies": {
    "@eslint/js": "*",
    "@eslint/eslintrc": "*",
    "@testing-library/dom": "*",
    "@testing-library/react": "*",
    "@testing-library/user-event": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitejs/plugin-react": "*",
    "@vitest/coverage-v8": "*",
    "bestzip": "*",
    "eslint": "*",
    "eslint-config-next": "*",
    "eslint-config-typescript": "*",
    "happy-dom": "*",
    "jscpd": "*",
    "jsdom": "*",
    "next-router-mock": "*",
    "puppeteer": "*",
    "typescript": "*",
    "typescript-eslint": "*",
    "vite-tsconfig-paths": "*",
    "vitest": "*"
  },
  "scripts": {
    "docker": "(docker compose down) && (docker compose up -d)",
    "lint": "eslint src/app/**/* --fix",
    "cpd": "jscpd src --silent",
    "predev": "(npm run lint) && (npm run cpd)",
    "dev": "next dev",
    "rdev": "next dev",
    "prebuild": "(npm run lint) && (npm run cpd)",
    "build": "next build",
    "rbuild": "next build",
    "prestart": "npm run build",
    "start": "next start",
    "rstart": "next start",
    "pretest": "(npm run lint) && (npm run cpd)",
    "test": "vitest run --dir test --no-file-parallelism --testTimeout=3000 --coverage",
    "rtest": "vitest run --dir test --no-file-parallelism --testTimeout=3000 --coverage",
    "re2e": "vitest run --dir e2e --no-file-parallelism --testTimeout=20000",
    "e2e": "(npm run docker) && (npm run re2e)",
    "package": "docker buildx build --platform linux/amd64 -t helloworld:latest --load . && mkdir -p dist && docker save helloworld:latest | gzip > dist/helloworld.tar.gz && echo \"\\n→ dist/helloworld.tar.gz ready ($(du -h dist/helloworld.tar.gz | cut -f1))\""
  }
}
